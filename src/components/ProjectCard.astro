---
import Icon from './Icon.astro';

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  dates: string;
  tags: readonly string[];
  image?: string;
  links?: readonly { icon: string; type: string; href: string }[];
}

const { title, subtitle, description, dates, tags, image, links } = Astro.props;
---

<div class="project-card">
  {image && (
    <div class="project-img-wrap">
      <img src={image} alt={title} width="540" height="176" loading="lazy" />
    </div>
  )}

  <div class="project-body">
    <div>
      <div style="display: flex; align-items: center; justify-content: space-between">
        <h3 class="project-title">
          {title}
          {subtitle && <span class="project-subtitle">({subtitle})</span>}
        </h3>
      </div>
      <p class="project-dates">{dates}</p>
    </div>

    <p class="project-desc">{description}</p>

    {tags && tags.length > 0 && (
      <div class="project-tags">
        {tags.map((tag) => (
          <span class="project-tag">{tag}</span>
        ))}
      </div>
    )}

    {links && links.length > 0 && (
      <div class="project-links">
        {links.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="project-link">
            <Icon name={link.icon} />
            <span>{link.type}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</div>
