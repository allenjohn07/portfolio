---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description="Blog posts by Allen John">
  <main>
    <section>
      <a href="/" class="back-link">← Back home</a>
      <h1 style="font-size: 1.875rem; font-weight: 700; margin-bottom: 1.5rem;">Blog</h1>

      {posts.length === 0 ? (
        <div class="empty-state">
          <p>No posts yet. Check back soon!</p>
        </div>
      ) : (
        <div class="blog-list">
          {posts.map((post) => (
            <article class="blog-item fade-in">
              <h3>
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </h3>
              <p class="blog-date">
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
              <p class="blog-desc">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="blog-tags">
                  {post.data.tags.map((tag) => (
                    <span class="project-tag">{tag}</span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      )}
    </section>
  </main>
</BaseLayout>
